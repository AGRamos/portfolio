---
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;

const sorted = [...projects].sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<section aria-labelledby="projects-heading" class="relative border-t border-[var(--color-cream-rule)] dark:border-[var(--color-surface-rule)] px-6 py-24 sm:px-12 lg:px-16">
  <div class="mx-auto w-full max-w-7xl">
    <div class="grid grid-cols-12 gap-y-10 lg:gap-x-8">
      <div class="col-span-12 lg:col-span-3 fade-up">
        <p class="font-eyebrow text-[10px] tracking-[0.35em] uppercase text-amber-600 dark:text-amber-400">
          № 05 / Selected
        </p>
        <h2 id="projects-heading" class="mt-3 font-display text-4xl font-light tracking-tight sm:text-5xl">
          Projects
        </h2>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
          A curated set of work that blends Salesforce, AI, and modern web architecture.
        </p>
      </div>

      <div class="col-span-12 lg:col-span-9 fade-up" style="transition-delay: 120ms;">
        <ol class="space-y-0 divide-y divide-[var(--color-cream-rule)] dark:divide-[var(--color-surface-rule)]">
          {sorted.map((project, idx) => (
            <li class="group grid grid-cols-12 gap-4 py-10 transition-colors sm:gap-6 sm:py-12">
              <div class="col-span-2 sm:col-span-1">
                <p class="font-eyebrow text-[10px] tracking-[0.3em] uppercase text-amber-600 dark:text-amber-400">
                  {String(idx + 1).padStart(2, '0')}
                </p>
                {project.data.featured && (
                  <p class="mt-2 font-eyebrow text-[9px] tracking-[0.3em] uppercase text-amber-500">
                    ★ Featured
                  </p>
                )}
              </div>

              <div class="col-span-10 sm:col-span-7">
                <h3 class="font-display text-2xl font-light leading-tight tracking-tight sm:text-3xl">
                  {project.data.title}
                </h3>
                <p class="mt-3 max-w-2xl text-sm leading-relaxed text-[var(--color-ink-soft)] dark:text-[var(--color-cream-2)] sm:text-[15px]">
                  {project.data.description}
                </p>

                <div class="mt-5 flex flex-wrap gap-1.5">
                  {project.data.technologies.map((tech) => (
                    <span class="rounded-sm border border-[var(--color-cream-rule)] bg-[var(--color-cream-1)] px-2 py-0.5 font-mono text-[10px] tracking-wider text-[var(--color-ink-soft)] dark:border-[var(--color-surface-rule)] dark:bg-[var(--color-surface-1)] dark:text-[var(--color-cream-2)]">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>

              <div class="col-span-12 flex items-start justify-end gap-4 sm:col-span-4 sm:flex-col sm:items-end sm:gap-3">
                {project.data.github && (
                  <a
                    href={project.data.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`View ${project.data.title} source code on GitHub`}
                    class="group/link inline-flex items-center gap-2 font-eyebrow text-[10px] tracking-[0.2em] uppercase text-[var(--color-ink-soft)] transition-colors hover:text-amber-600 dark:text-[var(--color-cream-2)] dark:hover:text-amber-400"
                  >
                    Source
                    <svg class="h-3 w-3 transition-transform group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                )}
                {project.data.live && (
                  <a
                    href={project.data.live}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`View ${project.data.title} live demo`}
                    class="group/link inline-flex items-center gap-2 font-eyebrow text-[10px] tracking-[0.2em] uppercase text-amber-600 transition-colors hover:text-amber-500 dark:text-amber-400"
                  >
                    Live
                    <svg class="h-3 w-3 transition-transform group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                )}
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>
</section>