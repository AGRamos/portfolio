---
import type { CollectionEntry } from 'astro:content';

interface Props {
  certifications: CollectionEntry<'certifications'>[];
}

const { certifications } = Astro.props;

const sorted = [...certifications].sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<section aria-labelledby="cert-heading" class="relative border-t border-[var(--color-cream-rule)] dark:border-[var(--color-surface-rule)] px-6 py-24 sm:px-12 lg:px-16">
  <div class="mx-auto w-full max-w-7xl">
    <div class="grid grid-cols-12 gap-y-10 lg:gap-x-8">
      <div class="col-span-12 lg:col-span-3 fade-up">
        <p class="font-eyebrow text-[10px] tracking-[0.35em] uppercase text-amber-600 dark:text-amber-400">
          № 07 / Verified
        </p>
        <h2 id="cert-heading" class="mt-3 font-display text-4xl font-light tracking-tight sm:text-5xl">
          Certifi-<br />
          <span class="italic text-amber-600 dark:text-amber-400">cations</span>
        </h2>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
          Salesforce credentials earned and currently active.
        </p>
      </div>

      <ul class="col-span-12 lg:col-span-9 fade-up" style="transition-delay: 120ms;">
        {sorted.map((cert, i) => (
          <li class="group grid grid-cols-12 items-baseline gap-4 border-b border-[var(--color-cream-rule)] py-6 first:border-t-0 last:border-b-0 transition-colors hover:bg-[var(--color-cream-1)] sm:gap-6 sm:py-7 dark:border-[var(--color-surface-rule)] dark:hover:bg-[var(--color-surface-1)]">
            <div class="col-span-2 sm:col-span-1">
              <p class="font-eyebrow text-[10px] tracking-[0.3em] uppercase text-amber-600 dark:text-amber-400">
                {String(i + 1).padStart(2, '0')}
              </p>
            </div>
            <div class="col-span-10 sm:col-span-8">
              <h3 class="text-base font-medium tracking-tight text-[var(--color-surface-0)] dark:text-[var(--color-cream-0)] sm:text-lg">
                {cert.data.name}
              </h3>
              <p class="mt-0.5 font-eyebrow text-[10px] tracking-[0.2em] uppercase text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                {cert.data.issuer}
              </p>
            </div>
            <div class="col-span-12 sm:col-span-3 sm:text-right">
              <p class="font-display text-2xl font-light tabular-nums text-amber-600 dark:text-amber-400 sm:text-3xl">
                {cert.data.year}
              </p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>