---
interface Props {
  title: string;
  description: string;
  technologies: string[];
  github?: string;
  live?: string;
  featured?: boolean;
}

const { title, description, technologies, github, live, featured = false } = Astro.props;
---

<article
  class="group relative flex flex-col justify-between rounded-sm border border-[var(--color-cream-3)] bg-[var(--color-cream-1)] p-6 transition-all duration-300 hover:border-amber-400 hover:shadow-lg hover:-translate-y-0.5 dark:border-[var(--color-surface-3)] dark:bg-[var(--color-surface-1)] dark:hover:border-amber-600"
>
  {featured && (
    <span class="absolute -top-3 right-6 rounded-sm bg-amber-500 px-2 py-0.5 font-mono text-[10px] font-medium tracking-wider text-white uppercase">
      Featured
    </span>
  )}

  <div>
    <h3 class="text-lg font-bold tracking-tight">{title}</h3>
    <p class="mt-3 text-sm leading-relaxed text-[var(--color-surface-2)] dark:text-[var(--color-cream-2)]">
      {description}
    </p>
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    {technologies.map((tech) => (
      <span class="rounded-sm bg-[var(--color-cream-2)] px-2 py-0.5 font-mono text-[10px] tracking-wider text-[var(--color-surface-1)] dark:bg-[var(--color-surface-2)] dark:text-[var(--color-cream-2)]">
        {tech}
      </span>
    ))}
  </div>

  {(github || live) && (
    <div class="mt-6 flex gap-4">
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${title} source code on GitHub`}
          class="inline-flex items-center gap-1.5 text-xs font-medium text-[var(--color-surface-1)] transition-colors hover:text-amber-600 dark:text-[var(--color-cream-0)] dark:hover:text-amber-400"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          Source
        </a>
      )}
      {live && (
        <a
          href={live}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${title} live demo`}
          class="inline-flex items-center gap-1.5 text-xs font-medium text-[var(--color-surface-1)] transition-colors hover:text-amber-600 dark:text-[var(--color-cream-0)] dark:hover:text-amber-400"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6m0 0v6m0-6L10 14" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Live
        </a>
      )}
    </div>
  )}
</article>