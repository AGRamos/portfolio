---
const skills = [
  {
    category: 'Salesforce',
    proficiency: 'primary',
    items: ['Apex', 'LWC', 'Aura', 'Flows', 'SOQL/SOSL', 'REST/SOAP APIs', 'Lightning App Builder'],
  },
  {
    category: 'AI & Agentforce',
    proficiency: 'frequent',
    items: ['Agentforce', 'Agent Orchestration', 'Einstein', 'Prompt Design', 'WhatsApp / Messaging Channels'],
  },
  {
    category: 'Salesforce Clouds',
    proficiency: 'primary',
    items: ['Sales Cloud', 'Service Cloud', 'Experience Cloud', 'Marketing Cloud', 'Vlocity / OmniStudio'],
  },
  {
    category: 'DevOps & Quality',
    proficiency: 'frequent',
    items: ['Azure DevOps', 'GitHub Actions', 'SFDX', 'CI/CD Pipelines', 'Code Review Standards'],
  },
  {
    category: 'Integration',
    proficiency: 'frequent',
    items: ['Genesys CTI', 'Payment Gateways', 'WhatsApp Business', 'Composite Resources', 'Platform Events'],
  },
  {
    category: 'Leadership',
    proficiency: 'primary',
    items: ['Tech Lead', 'Project Management', 'Cross-functional Coordination', 'Mentoring', 'Stakeholder Mgmt'],
  },
] as const;

const tierLabel: Record<typeof skills[number]['proficiency'], { text: string; class: string }> = {
  primary: { text: 'Primary', class: 'text-amber-600 dark:text-amber-400' },
  frequent: { text: 'Frequent', class: 'text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]' },
  working: { text: 'Working knowledge', class: 'text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)] italic' },
};
---

<section aria-labelledby="skills-heading" class="relative border-t border-[var(--color-cream-rule)] dark:border-[var(--color-surface-rule)] px-6 py-24 sm:px-12 lg:px-16">
  <div class="mx-auto w-full max-w-7xl">
    <div class="grid grid-cols-12 gap-y-10 lg:gap-x-8">
      <div class="col-span-12 lg:col-span-3 fade-up">
        <p class="font-eyebrow text-[10px] tracking-[0.35em] uppercase text-amber-600 dark:text-amber-400">
          № 05 / Toolkit
        </p>
        <h2 id="skills-heading" class="mt-3 font-display text-4xl font-light tracking-tight sm:text-5xl">
          Skills<br />
          <span class="italic text-amber-600 dark:text-amber-400">matrix</span>
        </h2>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
          Self-assessed map of where I spend my time. Tiers reflect daily fluency, not theoretical knowledge.
        </p>
      </div>

      <ul class="col-span-12 grid gap-px sm:grid-cols-2 lg:col-span-9 fade-up" style="transition-delay: 120ms;">
        {skills.map((s, i) => (
          <li class="group relative border border-[var(--color-cream-rule)] bg-[var(--color-cream-1)] p-6 transition-all duration-300 hover:border-amber-400 hover:bg-[var(--color-cream-0)] dark:border-[var(--color-surface-rule)] dark:bg-[var(--color-surface-1)] dark:hover:border-amber-600 dark:hover:bg-[var(--color-surface-2)] sm:p-7">
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-display text-2xl font-light tracking-tight">
                {s.category}
              </h3>
              <span class="font-eyebrow text-[10px] tracking-widest text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>

            <p class={`mt-4 font-eyebrow text-[10px] tracking-[0.3em] uppercase ${tierLabel[s.proficiency].class}`}>
              {tierLabel[s.proficiency].text}
            </p>

            <ul class="mt-5 flex flex-wrap gap-x-3 gap-y-1.5">
              {s.items.map((item) => (
                <li class="font-eyebrow text-[10px] tracking-wider text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                  <span class="text-amber-500">·</span> {item}
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
