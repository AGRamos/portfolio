---
const skills = [
  {
    category: 'Salesforce',
    level: 95,
    items: ['Apex', 'LWC', 'Flow', 'Agentforce', 'SOQL', 'SFDX', 'Platform Events'],
  },
  {
    category: 'AI & Agents',
    level: 85,
    items: ['LLM Orchestration', 'MCP', 'RAG', 'Vector DBs', 'Prompt Engineering', 'NLP'],
  },
  {
    category: 'Backend',
    level: 80,
    items: ['Python', 'Node.js', 'REST/SOAP', 'PostgreSQL', 'Redis', 'Docker'],
  },
  {
    category: 'Frontend',
    level: 78,
    items: ['TypeScript', 'React', 'Astro', 'Tailwind', 'Web Components'],
  },
  {
    category: 'DevOps',
    level: 75,
    items: ['GitHub Actions', 'Jenkins', 'AWS', 'CI/CD', 'Terraform', 'Monitoring'],
  },
  {
    category: 'Leadership',
    level: 88,
    items: ['Technical Strategy', 'Mentoring', 'Code Review', 'Architecture', 'Stakeholder Mgmt'],
  },
];
---

<section aria-labelledby="skills-heading" class="relative border-t border-[var(--color-cream-rule)] dark:border-[var(--color-surface-rule)] px-6 py-24 sm:px-12 lg:px-16">
  <div class="mx-auto w-full max-w-7xl">
    <div class="grid grid-cols-12 gap-y-10 lg:gap-x-8">
      <div class="col-span-12 lg:col-span-3 fade-up">
        <p class="font-eyebrow text-[10px] tracking-[0.35em] uppercase text-amber-600 dark:text-amber-400">
          № 04 / Toolkit
        </p>
        <h2 id="skills-heading" class="mt-3 font-display text-4xl font-light tracking-tight sm:text-5xl">
          Skills<br />
          <span class="italic text-amber-600 dark:text-amber-400">matrix</span>
        </h2>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
          A self-assessed map of where I spend my time. Levels reflect daily fluency, not theoretical knowledge.
        </p>
      </div>

      <ul class="col-span-12 grid gap-px sm:grid-cols-2 lg:col-span-9 fade-up" style="transition-delay: 120ms;">
        {skills.map((s, i) => (
          <li class="group relative border border-[var(--color-cream-rule)] bg-[var(--color-cream-1)] p-6 transition-all duration-300 hover:border-amber-400 hover:bg-[var(--color-cream-0)] dark:border-[var(--color-surface-rule)] dark:bg-[var(--color-surface-1)] dark:hover:border-amber-600 dark:hover:bg-[var(--color-surface-2)] sm:p-7">
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-display text-2xl font-light tracking-tight">
                {s.category}
              </h3>
              <span class="font-eyebrow text-[10px] tracking-widest text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>

            <div class="mt-5 flex items-center gap-3">
              <div class="relative h-1 flex-1 overflow-hidden bg-[var(--color-cream-2)] dark:bg-[var(--color-surface-3)]">
                <div
                  class="absolute inset-y-0 left-0 origin-left scale-x-0 bg-amber-500 transition-transform duration-1000 ease-out group-[.in]:scale-x-100"
                  style={`--target-scale: ${s.level / 100}; transition-delay: ${i * 80 + 200}ms;`}
                  data-fill={s.level}
                ></div>
              </div>
              <span class="font-display text-sm font-medium tabular-nums text-amber-600 dark:text-amber-400">
                {s.level}<span class="text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">%</span>
              </span>
            </div>

            <ul class="mt-5 flex flex-wrap gap-1.5">
              {s.items.map((item) => (
                <li class="font-eyebrow text-[10px] tracking-wider text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                  <span class="text-amber-500">·</span> {item}
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<script>
  const fillBars = document.querySelectorAll('[data-fill]');
  if (fillBars.length > 0) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const fill = parseFloat(el.dataset.fill || '0') / 100;
          el.style.transform = `scaleX(${fill})`;
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.2 });
    fillBars.forEach((el) => observer.observe(el));
  }
</script>