---
---

<section aria-labelledby="hero-heading" class="relative flex min-h-[90vh] flex-col justify-center px-6 py-24 sm:px-12 lg:px-24">
  <div class="mx-auto w-full max-w-5xl">
    <p class="font-mono text-sm tracking-widest text-amber-600 dark:text-amber-400 mb-4">
      &gt; Hello, world
    </p>
    <h1
      id="hero-heading"
      class="text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-7xl"
    >
      Senior Salesforce
      <br />
      Developer & Technical
      <br />
      <span class="text-amber-600 dark:text-amber-400">Lead</span>
    </h1>
    <p class="mt-8 max-w-2xl text-lg leading-relaxed text-[var(--color-surface-2)] dark:text-[var(--color-cream-2)] sm:text-xl">
      Building autonomous AI systems and scalable cloud architectures. I craft
      elegant solutions at the intersection of Salesforce, AI, and modern web development.
    </p>
    <div class="mt-12 flex flex-col gap-4 sm:flex-row sm:items-center">
      <a
        href="/cv.pdf"
        class="inline-flex items-center justify-center gap-2 rounded-sm bg-[var(--color-surface-0)] px-7 py-3.5 text-sm font-medium tracking-wide text-[var(--color-cream-0)] transition-all duration-200 hover:bg-amber-600 dark:bg-[var(--color-cream-0)] dark:text-[var(--color-surface-0)] dark:hover:bg-amber-500"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a2 2 0 002 2h14a2 2 0 002-2v-3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Download CV
      </a>
      <a
        href="#contact"
        class="inline-flex items-center justify-center gap-2 rounded-sm border border-[var(--color-surface-2)] px-7 py-3.5 text-sm font-medium tracking-wide transition-all duration-200 hover:border-[var(--color-surface-0)] hover:bg-[var(--color-surface-0)] hover:text-[var(--color-cream-0)] dark:border-[var(--color-cream-3)] dark:text-[var(--color-cream-0)] dark:hover:border-[var(--color-cream-0)] dark:hover:bg-[var(--color-cream-0)] dark:hover:text-[var(--color-surface-0)]"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Contact Me
      </a>
    </div>
  </div>

  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
    <svg class="h-6 w-6 text-[var(--color-surface-2)] dark:text-[var(--color-cream-2)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path d="M19 14l-7 7m0 0l-7-7m7 7V3" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>
</section>