---
import { Image } from 'astro:assets';
import heroPortrait from '../assets/hero-portrait.jpg';
import heroData from '../data/hero.json';

const { stats, rotating } = heroData;
---

<section aria-labelledby="hero-heading" class="relative flex min-h-[90vh] flex-col justify-center overflow-hidden px-6 pt-24 pb-16 sm:px-12 lg:px-16">
  <div class="pointer-events-none absolute inset-0 -z-0" aria-hidden="true">
    <svg class="absolute inset-0 h-full w-full opacity-[0.07] dark:opacity-[0.05]" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-grid" x="0" y="0" width="64" height="64" patternUnits="userSpaceOnUse">
          <path d="M 64 0 L 0 0 0 64" fill="none" stroke="currentColor" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)" class="text-[var(--color-surface-0)] dark:text-[var(--color-cream-0)]" />
    </svg>

    <div class="absolute -top-32 -right-32 h-[28rem] w-[28rem] rounded-full bg-amber-500/15 blur-3xl dark:bg-amber-500/10"></div>
    <div class="absolute -bottom-40 -left-32 h-[24rem] w-[24rem] rounded-full bg-amber-400/10 blur-3xl dark:bg-amber-400/5"></div>
  </div>

  <div class="relative z-10 mx-auto w-full max-w-7xl">
    <div class="grid grid-cols-12 gap-y-12 lg:gap-x-8">
      <div class="col-span-12 lg:col-span-3 fade-up" style="transition-delay: 0ms;">
        <p class="font-eyebrow text-[10px] tracking-[0.35em] uppercase text-amber-600 dark:text-amber-400">
          № 01 / Portfolio
        </p>
        <p class="mt-2 font-eyebrow text-[10px] tracking-[0.2em] uppercase text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
          Alcorcón, Madrid
        </p>
        <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1.5">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
          </span>
          <span class="font-eyebrow text-[9px] tracking-[0.2em] uppercase text-emerald-700 dark:text-emerald-400">
            Open to work
          </span>
        </div>

        <figure class="mt-10 flex flex-col items-start gap-3 sm:flex-row sm:items-center sm:gap-5 lg:flex-col lg:items-start">
          <div class="relative inline-block shrink-0">
            <div class="absolute -inset-3 rounded-full bg-gradient-to-br from-amber-500/50 via-amber-400/20 to-transparent blur-md" aria-hidden="true"></div>
            <Image
              src={heroPortrait}
              alt="Portrait of Alejandro Garrido"
              widths={[160, 192, 240, 288]}
              sizes="(min-width: 1280px) 288px, (min-width: 1024px) 240px, (min-width: 640px) 192px, 160px"
              height={288}
              loading="eager"
              fetchpriority="high"
              class="relative h-40 w-40 rounded-full border-2 border-amber-500 object-cover shadow-xl transition-transform duration-500 hover:scale-[1.03] sm:h-48 sm:w-48 lg:h-60 lg:w-60 xl:h-72 xl:w-72"
            />
          </div>
          <figcaption class="font-eyebrow text-[10px] tracking-[0.25em] uppercase text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)] lg:mt-4">
            <span class="block">Alejandro G.</span>
            <span class="mt-1 block text-[9px] text-amber-600 dark:text-amber-400">Sr. Salesforce Dev</span>
          </figcaption>
        </figure>
      </div>

      <div class="col-span-12 lg:col-span-6 fade-up" style="transition-delay: 100ms;">
        <p class="font-eyebrow text-xs tracking-widest text-amber-600 dark:text-amber-400">
          &gt; Hello, world_
        </p>
        <h1
          id="hero-heading"
          class="mt-6 font-display text-[clamp(2.5rem,7vw,6.5rem)] font-light leading-[0.95] tracking-[-0.04em]"
        >
          Alejandro<br />
          <span class="italic font-normal text-amber-600 dark:text-amber-400">Garrido</span><span class="text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">.</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-[var(--color-ink-soft)] dark:text-[var(--color-cream-2)]">
          Senior Salesforce Developer &amp; Project Manager crafting
          <span class="font-eyebrow text-sm text-amber-700 dark:text-amber-400" data-rotating data-phrases={JSON.stringify(rotating)}>
            Agentforce-powered AI agents
          </span>
          <span data-typed-cursor class="cursor-blink text-amber-500"></span>
          and full-stack LWC experiences for ambitious teams.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="https://linkedin.com/in/alejandrogrd"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative inline-flex items-center justify-center gap-3 overflow-hidden rounded-sm border border-[var(--color-surface-0)] bg-[var(--color-surface-0)] px-7 py-3.5 text-sm font-medium tracking-wide text-[var(--color-cream-0)] transition-all duration-300 hover:border-amber-500 hover:bg-amber-500 dark:border-[var(--color-cream-0)] dark:bg-[var(--color-cream-0)] dark:text-[var(--color-surface-0)] dark:hover:border-amber-500 dark:hover:bg-amber-500 dark:hover:text-[var(--color-surface-0)]"
          >
            <span class="relative z-10">LinkedIn Profile</span>
            <svg class="h-4 w-4 relative z-10 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a
            href="#contact"
            class="group inline-flex items-center gap-2 px-3 py-3.5 text-sm font-medium tracking-wide text-[var(--color-ink-soft)] transition-colors duration-300 hover:text-amber-600 dark:text-[var(--color-cream-2)] dark:hover:text-amber-400"
          >
            <span class="font-eyebrow text-[10px] tracking-[0.3em] uppercase text-amber-600 dark:text-amber-400 transition-colors group-hover:text-amber-500">
              →
            </span>
            <span class="border-b border-current pb-0.5">Get in touch</span>
          </a>
        </div>
      </div>

      <aside class="col-span-12 lg:col-span-3 lg:border-l lg:border-[var(--color-cream-rule)] lg:dark:border-[var(--color-surface-rule)] lg:pl-8 fade-up" style="transition-delay: 220ms;">
        <p class="font-eyebrow text-[10px] tracking-[0.3em] uppercase text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
          By the numbers
        </p>
        <dl class="mt-6 space-y-5">
          {stats.map((s) => (
            <div class="group">
              <dt class="font-display text-4xl font-light leading-none tracking-tight text-[var(--color-surface-0)] dark:text-[var(--color-cream-0)] sm:text-5xl">
                {s.value}
              </dt>
              <dd class="mt-1 text-xs font-medium text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                {s.label}
              </dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>
  </div>

  <div class="absolute bottom-8 left-6 hidden items-center gap-3 sm:flex sm:left-12 lg:left-16" aria-hidden="true">
    <div class="h-px w-12 bg-[var(--color-ink-mute)] dark:bg-[var(--color-cream-3)]"></div>
    <span class="font-eyebrow text-[10px] tracking-[0.3em] uppercase text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">Scroll</span>
  </div>
</section>

<script type="module">
  const el = document.querySelector('[data-rotating]') as HTMLElement | null;
  if (el) {
    const phrases: string[] = JSON.parse(el.dataset.phrases || '[]');
    let i = 0;
    let charIndex = 0;
    let deleting = false;

    const tick = () => {
      const phrase = phrases[i];
      if (!deleting) {
        el.textContent = phrase.slice(0, charIndex + 1);
        charIndex++;
        if (charIndex === phrase.length) {
          deleting = true;
          setTimeout(tick, 1800);
          return;
        }
      } else {
        el.textContent = phrase.slice(0, charIndex - 1);
        charIndex--;
        if (charIndex === 0) {
          deleting = false;
          i = (i + 1) % phrases.length;
        }
      }
      const delay = deleting ? 30 : 60;
      setTimeout(tick, delay);
    };

    setTimeout(tick, 800);
  }
</script>