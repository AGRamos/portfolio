---
const label = 'Toggle theme';
---

<button
  id="theme-toggle"
  type="button"
  role="switch"
  aria-label={label}
  aria-checked="true"
  class="group fixed top-6 right-6 z-50 flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-cream-3)] bg-[var(--color-cream-1)] text-[var(--color-surface-0)] shadow-sm transition-all duration-300 hover:border-amber-400 hover:shadow-md dark:border-[var(--color-surface-3)] dark:bg-[var(--color-surface-2)] dark:text-[var(--color-cream-0)]"
>
  <svg class="h-5 w-5 rotate-0 scale-100 transition-transform duration-300 group-hover:rotate-12 dark:rotate-90 dark:scale-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <circle cx="12" cy="12" r="5" />
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke-linecap="round" />
  </svg>
  <svg class="absolute h-5 w-5 rotate-90 scale-0 transition-transform duration-300 group-hover:rotate-12 dark:rotate-0 dark:scale-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
</button>

<script>
  const toggle = document.getElementById('theme-toggle') as HTMLButtonElement | null;
  if (toggle) {
    const updateToggle = () => {
      const isDark = document.documentElement.classList.contains('dark');
      toggle.setAttribute('aria-checked', isDark ? 'true' : 'false');
    };

    toggle.addEventListener('click', () => {
      const html = document.documentElement;
      html.classList.toggle('dark');
      localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
      updateToggle();
    });

    updateToggle();
  }

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
  } else {
    document.querySelectorAll('.fade-up').forEach((el) => el.classList.add('in'));
  }
</script>