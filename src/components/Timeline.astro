---
import type { CollectionEntry } from 'astro:content';

interface Props {
  experiences: CollectionEntry<'experience'>[];
}

const { experiences } = Astro.props;

const sorted = [...experiences].sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0) || b.data.startDate.localeCompare(a.data.startDate),
);

const formatDate = (dateStr: string) => {
  const [year, month] = dateStr.split('-');
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return `${months[parseInt(month) - 1]} ${year}`;
};

const getYear = (dateStr: string) => dateStr.split('-')[0];
---

<section aria-labelledby="experience-heading" class="relative border-t border-[var(--color-cream-rule)] dark:border-[var(--color-surface-rule)] px-6 py-24 sm:px-12 lg:px-16">
  <div class="mx-auto w-full max-w-7xl">
    <div class="grid grid-cols-12 gap-y-10 lg:gap-x-8">
      <div class="col-span-12 lg:col-span-3 fade-up">
        <p class="font-eyebrow text-[10px] tracking-[0.35em] uppercase text-amber-600 dark:text-amber-400">
          № 03 / Career
        </p>
        <h2 id="experience-heading" class="mt-3 font-display text-4xl font-light tracking-tight sm:text-5xl">
          Experience
        </h2>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
          A decade of building enterprise platforms, from junior developer to technical lead &mdash; with a focus on what moves the needle.
        </p>
      </div>

      <ol class="col-span-12 lg:col-span-9 fade-up" style="transition-delay: 120ms;">
        {sorted.map((exp, idx) => (
          <li class="group relative grid grid-cols-12 gap-4 border-b border-[var(--color-cream-rule)] py-10 first:border-t-0 last:border-b-0 transition-colors duration-300 dark:border-[var(--color-surface-rule)] sm:gap-6 sm:py-12">
            <div class="col-span-12 sm:col-span-3">
              <p class="font-eyebrow text-[10px] tracking-[0.3em] uppercase text-amber-600 dark:text-amber-400">
                {String(idx + 1).padStart(2, '0')} / {sorted.length}
              </p>
              <p class="mt-2 font-display text-5xl font-light leading-none tracking-tight text-[var(--color-surface-0)] dark:text-[var(--color-cream-0)] sm:text-6xl">
                {getYear(exp.data.startDate)}
              </p>
              <p class="mt-2 font-eyebrow text-[10px] tracking-widest text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                {formatDate(exp.data.startDate)} — {exp.data.endDate ? formatDate(exp.data.endDate) : 'Present'}
              </p>
              <p class="mt-1 font-eyebrow text-[10px] tracking-widest text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                {exp.data.location}
              </p>
            </div>

            <div class="col-span-12 sm:col-span-9">
              <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
                <h3 class="text-xl font-medium tracking-tight text-[var(--color-surface-0)] dark:text-[var(--color-cream-0)] sm:text-2xl">
                  {exp.data.role}
                </h3>
                <span class="font-display text-lg italic text-amber-600 dark:text-amber-400 sm:text-xl">
                  {exp.data.company}
                </span>
              </div>

              <ul class="mt-6 space-y-3">
                {exp.data.achievements.map((achievement) => (
                  <li class="relative pl-6 text-sm leading-relaxed text-[var(--color-ink-soft)] dark:text-[var(--color-cream-2)] sm:text-[15px]">
                    <span class="absolute left-0 top-[0.6rem] h-px w-3 bg-amber-500 transition-all duration-300 group-hover:w-5" aria-hidden="true"></span>
                    {achievement}
                  </li>
                ))}
              </ul>

              {exp.data.technologies && (
                <div class="mt-6 flex flex-wrap gap-1.5">
                  {exp.data.technologies.map((tech) => (
                    <span class="rounded-sm border border-[var(--color-cream-rule)] bg-[var(--color-cream-1)] px-2 py-0.5 font-mono text-[10px] tracking-wider text-[var(--color-ink-soft)] dark:border-[var(--color-surface-rule)] dark:bg-[var(--color-surface-1)] dark:text-[var(--color-cream-2)]">
                      {tech}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>