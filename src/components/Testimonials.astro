---
import type { CollectionEntry } from 'astro:content';

interface Props {
  testimonials: CollectionEntry<'testimonials'>[];
}

const { testimonials } = Astro.props;

const sorted = [...testimonials].sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<section aria-labelledby="testimonials-heading" class="relative border-t border-[var(--color-cream-rule)] dark:border-[var(--color-surface-rule)] px-6 py-24 sm:px-12 lg:px-16 bg-[var(--color-cream-1)] dark:bg-[var(--color-surface-1)]">
  <div class="mx-auto w-full max-w-7xl">
    <div class="grid grid-cols-12 gap-y-10 lg:gap-x-8">
      <div class="col-span-12 lg:col-span-3 fade-up">
        <p class="font-eyebrow text-[10px] tracking-[0.35em] uppercase text-amber-600 dark:text-amber-400">
          № 08 / Words
        </p>
        <h2 id="testimonials-heading" class="mt-3 font-display text-4xl font-light tracking-tight sm:text-5xl">
          Testi-<br />
          <span class="italic text-amber-600 dark:text-amber-400">monials</span>
        </h2>
      </div>

      <div class="col-span-12 lg:col-span-9 space-y-12 fade-up" style="transition-delay: 120ms;">
        {sorted.map((t, i) => (
          <figure class="group grid grid-cols-12 gap-4 sm:gap-6">
            <div class="col-span-2 sm:col-span-1">
              <p class="font-display text-5xl font-light leading-none text-amber-600 dark:text-amber-400 sm:text-6xl">
                &ldquo;
              </p>
              <p class="mt-2 font-eyebrow text-[10px] tracking-[0.3em] uppercase text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                {String(i + 1).padStart(2, '0')}
              </p>
            </div>
            <blockquote class="col-span-10 sm:col-span-8">
              <p class="font-display text-lg font-light leading-relaxed tracking-tight text-[var(--color-surface-0)] dark:text-[var(--color-cream-0)] sm:text-xl lg:text-2xl">
                {t.data.quote}
              </p>
              <figcaption class="mt-6 border-t border-[var(--color-cream-rule)] pt-4 dark:border-[var(--color-surface-rule)]">
                <p class="font-eyebrow text-[10px] tracking-[0.2em] uppercase text-amber-600 dark:text-amber-400">
                  {t.data.author}
                </p>
                <p class="mt-1 text-sm text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                  {t.data.role}
                </p>
              </figcaption>
            </blockquote>
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>