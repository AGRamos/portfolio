---
const socials = [
  { label: 'LinkedIn', href: 'https://linkedin.com/in/alejandrogrd', handle: '/in/alejandrogrd' },
  { label: 'GitHub', href: 'https://github.com/AGRamos', handle: '/AGRamos' },
  { label: 'Writing', href: '/blog/', handle: '/blog' },
];
---

<section id="contact" aria-labelledby="contact-heading" class="relative border-t border-[var(--color-cream-rule)] dark:border-[var(--color-surface-rule)] px-6 py-24 sm:px-12 lg:px-16">
  <div class="mx-auto w-full max-w-7xl">
    <div class="grid grid-cols-12 gap-y-10 lg:gap-x-8">
      <div class="col-span-12 lg:col-span-3 fade-up">
        <p class="font-eyebrow text-[10px] tracking-[0.35em] uppercase text-amber-600 dark:text-amber-400">
          № 09 / Contact
        </p>
        <h2 id="contact-heading" class="mt-3 font-display text-4xl font-light tracking-tight sm:text-5xl">
          Let's<br />
          <span class="italic text-amber-600 dark:text-amber-400">talk</span>.
        </h2>
      </div>

      <div class="col-span-12 lg:col-span-9 fade-up" style="transition-delay: 120ms;">
        <p class="max-w-2xl text-lg leading-relaxed text-[var(--color-ink-soft)] dark:text-[var(--color-cream-2)] sm:text-xl">
          I take on a small number of engagements each year &mdash; full-time roles, advisory work, and the occasional collaboration. If you're building something interesting, I'd love to hear about it.
        </p>

        <a
          id="contact-email"
          href="#"
          class="group mt-10 inline-flex items-baseline gap-3 font-display text-2xl font-light tracking-tight text-[var(--color-surface-0)] transition-colors hover:text-amber-600 dark:text-[var(--color-cream-0)] dark:hover:text-amber-400 sm:text-3xl lg:text-4xl"
        >
          <span class="border-b-2 border-current pb-1 transition-colors group-hover:border-amber-500" data-email-user="redacted" data-email-domain="gmail.com">
          </span>
          <svg class="h-6 w-6 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1 sm:h-8 sm:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <ul class="mt-16 grid grid-cols-1 gap-px sm:grid-cols-2">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer me"
                aria-label={`${s.label} profile`}
                class="group/social flex items-baseline justify-between border-t border-[var(--color-cream-rule)] py-5 transition-colors hover:border-amber-500 dark:border-[var(--color-surface-rule)]"
              >
                <div>
                  <p class="font-eyebrow text-[10px] tracking-[0.3em] uppercase text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                    {s.label}
                  </p>
                  <p class="mt-1 font-display text-xl font-light tracking-tight transition-colors group-hover/social:text-amber-600 dark:group-hover/social:text-amber-400">
                    {s.handle}
                  </p>
                </div>
                <svg class="h-4 w-4 text-[var(--color-ink-mute)] transition-all group-hover/social:translate-x-1 group-hover/social:-translate-y-1 group-hover/social:text-amber-500 dark:text-[var(--color-cream-3)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<footer class="border-t border-[var(--color-cream-rule)] dark:border-[var(--color-surface-rule)] px-6 py-10 sm:px-12 lg:px-16">
  <div class="mx-auto max-w-7xl flex flex-col items-start justify-between gap-4 text-xs text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)] sm:flex-row sm:items-center">
    <p class="font-eyebrow text-[10px] tracking-[0.2em] uppercase">
      &copy; {new Date().getFullYear()} &mdash; All rights reserved
    </p>
    <p class="font-eyebrow text-[10px] tracking-[0.2em] uppercase">
      Built with <span class="text-amber-500">Astro</span> + <span class="text-amber-500">Tailwind</span>
    </p>
  </div>
</footer>

<script type="module">
  const link = document.getElementById('contact-email');
  const text = link?.querySelector('[data-email-user]') as HTMLElement | null;
  if (link && text) {
    const u = text.dataset.emailUser!;
    const d = text.dataset.emailDomain!;
    const addr = `${u}@${d}`;
    link.href = `mailto:${addr}`;
    text.textContent = addr;
  }
</script>