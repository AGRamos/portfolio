---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const {
  title,
  description = 'Senior Salesforce Developer & Technical Lead building autonomous AI systems, agentic experiences, and modern web architecture.',
  image = `${base}/og-image.png`,
  type = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://example.com');
const fullImage = new URL(image, Astro.site ?? 'https://example.com').toString();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Alejandro Garrido" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />
    <link rel="alternate" type="application/rss+xml" title="Writing" href={`${base}/rss.xml`} />
    <link rel="webmention" href="https://webmention.io/agramos.github.io/webmention" />
    <link rel="pingback" href="https://webmention.io/agramos.github.io/xmlrpc" />
    <meta name="theme-color" content="#0a0a0b" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafaf8" media="(prefers-color-scheme: light)" />
    <meta name="color-scheme" content="light dark" />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Portfolio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImage} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImage} />

    <style is:global>
      @import "../styles/global.css";
    </style>
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else if (!window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="min-h-screen transition-colors duration-300 bg-[var(--color-cream-0)] text-[var(--color-surface-0)] dark:bg-[var(--color-surface-0)] dark:text-[var(--color-cream-0)]">
    <slot />
  </body>
</html>