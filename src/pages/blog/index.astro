---
import Layout from '../../layouts/Layout.astro';
import ScrollProgress from '../../components/ScrollProgress.astro';
import { getCollection, render } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Writing — Alejandro Garrido" description="Notes on Salesforce, Agentforce, AI, and building software in production.">
  <ScrollProgress />
  <main class="grain min-h-screen px-6 py-24 sm:px-12 lg:px-16">
    <div class="mx-auto w-full max-w-3xl">
      <a href={`${base}/`} class="inline-flex items-center gap-2 font-eyebrow text-[10px] tracking-[0.2em] uppercase text-[var(--color-ink-mute)] transition-colors hover:text-amber-600 dark:text-[var(--color-cream-3)] dark:hover:text-amber-400">
        <span>←</span> Back home
      </a>

      <p class="mt-12 font-eyebrow text-[10px] tracking-[0.35em] uppercase text-amber-600 dark:text-amber-400">
        Writing
      </p>
      <h1 class="mt-3 font-display text-5xl font-light tracking-tight sm:text-6xl">
        Notes
      </h1>
      <p class="mt-4 max-w-xl text-[var(--color-ink-soft)] dark:text-[var(--color-cream-2)]">
        Notes on Salesforce, Agentforce, AI integrations, and the things I learn building in production.
      </p>

      {posts.length === 0 ? (
        <p class="mt-20 font-display text-xl italic text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
          No posts yet. Check back soon.
        </p>
      ) : (
        <ol class="mt-16 space-y-0 divide-y divide-[var(--color-cream-rule)] dark:divide-[var(--color-surface-rule)]">
          {posts.map((post) => (
            <li class="group py-8 transition-colors">
              <a href={`${base}/blog/${post.id}/`} class="block">
                <p class="font-eyebrow text-[10px] tracking-[0.2em] uppercase text-[var(--color-ink-mute)] dark:text-[var(--color-cream-3)]">
                  <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                  {post.data.tags.length > 0 && (
                    <span> · {post.data.tags.join(' · ')}</span>
                  )}
                </p>
                <h2 class="mt-3 font-display text-2xl font-light leading-tight tracking-tight transition-colors group-hover:text-amber-600 dark:group-hover:text-amber-400 sm:text-3xl">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-soft)] dark:text-[var(--color-cream-2)] sm:text-[15px]">
                  {post.data.description}
                </p>
                <p class="mt-4 inline-flex items-center gap-2 font-eyebrow text-[10px] tracking-[0.2em] uppercase text-amber-600 transition-transform duration-300 group-hover:translate-x-1 dark:text-amber-400">
                  Read
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </p>
              </a>
            </li>
          ))}
        </ol>
      )}
    </div>
  </main>
</Layout>