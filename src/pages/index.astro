---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import Hero from '../components/Hero.astro';
import Now from '../components/Now.astro';
import Timeline from '../components/Timeline.astro';
import Education from '../components/Education.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import Certifications from '../components/Certifications.astro';
import Contact from '../components/Contact.astro';
import { getCollection } from 'astro:content';

const experiences = await getCollection('experience');
const projects = await getCollection('projects');
const certifications = await getCollection('certifications');
const degrees = await getCollection('education');
const nowItems = await getCollection('now');

const buildDate = new Date();
const lastUpdated = buildDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const lastUpdatedISO = `${buildDate.getFullYear()}-${String(buildDate.getMonth() + 1).padStart(2, '0')}`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Alejandro Garrido',
  jobTitle: 'Senior Salesforce Developer & AI Engineer',
  url: Astro.site?.toString(),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Alcorcón',
    addressRegion: 'Madrid',
    addressCountry: 'ES',
  },
  worksFor: { '@type': 'Organization', name: 'Accenture' },
  sameAs: ['https://linkedin.com/in/alejandrogrd', 'https://github.com/AGRamos'],
  knowsAbout: ['Salesforce', 'Agentforce', 'LLM Engineering', 'Lightning Web Components', 'AI Agents'],
};
---

<Layout title="Alejandro Garrido — Senior Salesforce Developer & AI Engineer" description="Senior Salesforce Developer and AI Engineer building Agentforce-powered AI systems, multi-cloud ecosystems, and full-stack LWC experiences.">
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[60] focus:rounded-sm focus:bg-amber-500 focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-[var(--color-surface-0)]"
  >
    Skip to content
  </a>
  <ThemeToggle />
  <ScrollProgress />
  <main id="main-content" class="grain">
    <Hero />
    <Now nowItems={nowItems} lastUpdated={lastUpdated} lastUpdatedISO={lastUpdatedISO} />
    <Timeline experiences={experiences} />
    <Education degrees={degrees} />
    <Skills />
    <Projects projects={projects} />
    <Certifications certifications={certifications} />
    <Contact />
  </main>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
</Layout>