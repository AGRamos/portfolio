---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="404 — Page not found" description="The page you're looking for doesn't exist.">
  <main class="grain flex min-h-screen items-center justify-center px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-eyebrow text-[10px] tracking-[0.35em] uppercase text-amber-700 dark:text-amber-400">
        Error 404
      </p>
      <h1 class="mt-6 font-display text-7xl font-light tracking-tight sm:text-9xl">
        <span class="italic text-amber-600 dark:text-amber-400">Lost</span>
      </h1>
      <p class="mt-6 text-lg text-[var(--color-ink-soft)] dark:text-[var(--color-cream-2)]">
        The page you’re looking for doesn’t exist or has been moved.
      </p>
      <a
        href={`${base}/`}
        class="group mt-10 inline-flex items-center gap-2 rounded-sm border border-[var(--color-surface-0)] bg-[var(--color-surface-0)] px-7 py-3.5 text-sm font-medium tracking-wide text-[var(--color-cream-0)] transition-colors hover:border-amber-500 hover:bg-amber-500 dark:border-[var(--color-cream-0)] dark:bg-[var(--color-cream-0)] dark:text-[var(--color-surface-0)] dark:hover:bg-amber-500 dark:hover:border-amber-500"
      >
        <span class="font-eyebrow text-[10px] tracking-[0.3em] uppercase text-amber-400 dark:text-amber-600 group-hover:text-white dark:group-hover:text-[var(--color-surface-0)]">←</span>
        Back home
      </a>
    </div>
  </main>
</Layout>